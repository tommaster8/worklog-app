rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Employees can read their own data + factories/projects
    match /employees/{empId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /factories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /workSessions/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    match /absences/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }
  }
}
